<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="48dp">

    <!-- Header with restaurant name and logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/restaurantName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Restaurant Name"
            android:textSize="36sp"
            android:textColor="#FF6B35"
            android:textStyle="bold" />

        <!-- QR Code area -->
        <FrameLayout
            android:id="@+id/qrCodeContainer"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="#FFFFFF"
            android:padding="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="QR\nCode"
                android:textColor="#000000"
                android:textSize="14sp" />
        </FrameLayout>
    </LinearLayout>

    <!-- Category tabs (horizontal scroll) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/categoryTabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Menu items grid -->
    <androidx.leanback.widget.VerticalGridView
        android:id="@+id/menuGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

    <!-- Footer: daily specials / promotions -->
    <TextView
        android:id="@+id/promoBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="Today's Special: 20% off all Pizzas!"
        android:textSize="22sp"
        android:textColor="#22C55E"
        android:textStyle="italic"
        android:gravity="center" />

</LinearLayout>
