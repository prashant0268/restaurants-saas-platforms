rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && role in getUserData().roles;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isRestaurantOwner(restaurantId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    function isRestaurantStaff(restaurantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/restaurants/$(restaurantId)/staff/$(request.auth.uid));
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Restaurants
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasRole('owner');
      allow update: if isRestaurantOwner(restaurantId) || isRestaurantStaff(restaurantId) || isAdmin();
      allow delete: if isAdmin();

      // Menu Items (subcollection)
      match /menuItems/{itemId} {
        allow read: if true;
        allow write: if isRestaurantOwner(restaurantId) || isRestaurantStaff(restaurantId) || isAdmin();
      }

      // Menu Categories (subcollection)
      match /menuCategories/{categoryId} {
        allow read: if true;
        allow write: if isRestaurantOwner(restaurantId) || isRestaurantStaff(restaurantId) || isAdmin();
      }

      // Reviews (subcollection)
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isOwner(resource.data.customerId) || isRestaurantOwner(restaurantId) || isAdmin();
        allow delete: if isAdmin();
      }

      // Staff (subcollection)
      match /staff/{staffId} {
        allow read: if isRestaurantOwner(restaurantId) || isRestaurantStaff(restaurantId) || isAdmin();
        allow write: if isRestaurantOwner(restaurantId) || isAdmin();
      }
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isRestaurantOwner(resource.data.restaurantId) ||
        isRestaurantStaff(resource.data.restaurantId) ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isRestaurantOwner(resource.data.restaurantId) ||
        isRestaurantStaff(resource.data.restaurantId) ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Reservations
    match /reservations/{reservationId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isRestaurantOwner(resource.data.restaurantId) ||
        isRestaurantStaff(resource.data.restaurantId) ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        isRestaurantOwner(resource.data.restaurantId) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Delivery Assignments
    match /deliveryAssignments/{assignmentId} {
      allow read: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid ||
        resource.data.customerId == request.auth.uid ||
        isRestaurantOwner(resource.data.restaurantId) ||
        isAdmin()
      );
      allow create: if isAdmin() || hasRole('staff');
      allow update: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Drivers
    match /drivers/{driverId} {
      allow read: if isOwner(driverId) || isAdmin();
      allow create: if isOwner(driverId);
      allow update: if isOwner(driverId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Driver Locations (real-time)
    match /driverLocations/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(driverId);
    }

    // Campaigns (marketing)
    match /campaigns/{campaignId} {
      allow read: if hasRole('marketing') || hasRole('admin');
      allow write: if hasRole('marketing') || hasRole('admin');
    }

    // Promotions
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if hasRole('marketing') || hasRole('admin') || (
        isAuthenticated() && resource != null && isRestaurantOwner(resource.data.restaurantId)
      );
    }

    // Leads (sales)
    match /leads/{leadId} {
      allow read: if hasRole('sales') || hasRole('admin');
      allow write: if hasRole('sales') || hasRole('admin');
    }

    // Subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || hasRole('sales') || isAdmin()
      );
      allow write: if hasRole('sales') || isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // Analytics
    match /analytics/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Support Tickets
    match /supportTickets/{ticketId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Platform Settings
    match /platformSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Loyalty Programs
    match /loyaltyPrograms/{programId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isAuthenticated() && resource != null && isRestaurantOwner(resource.data.restaurantId)
      );
    }

    // Customer Loyalty
    match /customerLoyalty/{loyaltyId} {
      allow read: if isAuthenticated() && resource.data.customerId == request.auth.uid;
      allow write: if isAdmin();
    }

    // Fire TV Displays
    match /fireTvDisplays/{displayId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        isRestaurantOwner(resource.data.restaurantId) || isAdmin()
      );
    }
  }
}
